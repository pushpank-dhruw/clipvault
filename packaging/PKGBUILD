# Maintainer: Pushpank Dhruw <pushpank1010@gmail.com>
pkgname=clipvault
pkgver=0.1.0
pkgrel=1
pkgdesc="Wayland-native clipboard history manager with a GPU-accelerated notch shelf (Hyprland)"
arch=('x86_64')
url="https://github.com/pushpank-dhruw/clipvault"
license=('MIT')
depends=('wl-clipboard' 'gcc-libs' 'glibc')
optdepends=('hyprland: source-app tracking and window rule integration')
makedepends=('cargo')
# !lto: makepkg's -flto=auto turns the bundled SQLite into GCC bitcode that
# ld.lld cannot link; Cargo's own release LTO still applies to the Rust side.
options=('!lto')
source=("$pkgname-$pkgver.tar.gz::$url/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('87fd1ecce1ab8330d438332a9f0b341d59f8ffb067f00a46b33aee7cd603168e')

prepare() {
  cd "$pkgname-$pkgver"
  export RUSTUP_TOOLCHAIN=stable
  cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
  cd "$pkgname-$pkgver"
  export RUSTUP_TOOLCHAIN=stable
  export CARGO_TARGET_DIR=target
  cargo build --frozen --release
}

check() {
  cd "$pkgname-$pkgver"
  export RUSTUP_TOOLCHAIN=stable
  cargo test --frozen --release
}

package() {
  cd "$pkgname-$pkgver"
  install -Dm0755 "target/release/$pkgname" "$pkgdir/usr/bin/$pkgname"
  install -Dm0644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
  install -Dm0644 packaging/clipvault.service "$pkgdir/usr/lib/systemd/user/clipvault.service"
  install -Dm0644 packaging/hyprland-clipvault.conf "$pkgdir/usr/share/clipvault/hyprland-clipvault.conf"
  install -Dm0644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
}
